# Load workspace names from file (one name per line, sorted
# alphabetically). Falls back to a small built-in list if the file
# is missing.
_WORKTREE_NAMES_FILE="${0:A:h}/../data/workspace-names.txt"
if [[ -f "$_WORKTREE_NAMES_FILE" ]]; then
    _WORKTREE_NAMES=("${(@f)$(< "$_WORKTREE_NAMES_FILE")}")
else
    _WORKTREE_NAMES=(alpha bravo charlie delta echo foxtrot golf hotel
        india juliet kilo lima mike november oscar papa quebec romeo
        sierra tango uniform victor whiskey xray yankee zulu)
fi

# Get a random worktree name not already in use for a given repo
_get_worktree_name() {
    local repo_dir="$HOME/.claude/worktrees/$1"
    local attempts=0
    local max_attempts=50

    while [[ $attempts -lt $max_attempts ]]; do
        local idx=$((RANDOM % ${#_WORKTREE_NAMES[@]}))
        local name="${_WORKTREE_NAMES[$idx]}"

        # Check if this name is already in use
        if [[ ! -d "$repo_dir/$name" ]]; then
            echo "$name"
            return 0
        fi
        ((attempts++))
    done

    # Fallback: append a number to a random name
    local base="${_WORKTREE_NAMES[$((RANDOM % ${#_WORKTREE_NAMES[@]}))]}"
    local n=2
    while [[ -d "$repo_dir/${base}-${n}" ]]; do
        ((n++))
    done
    echo "${base}-${n}"
}

# Start Claude Code in a new worktree
# Prompts for context, generates a descriptive name via Claude,
# then launches a session with the context as the initial prompt.
# Must be run from within a git repository.
cldw() {
    # Check if we're in a git repo
    local git_root
    git_root=$(git rev-parse --show-toplevel 2>/dev/null)
    if [[ -z "$git_root" ]]; then
        echo "Error: not in a git repository"
        return 1
    fi

    # Detect the real repo name (handles being inside a worktree)
    local repo_name
    local git_common_dir
    git_common_dir=$(git rev-parse --git-common-dir 2>/dev/null)
    if [[ "$git_common_dir" == *"/git/"*"/.git" ]]; then
        repo_name=$(basename "$(dirname "$git_common_dir")")
    elif [[ "$git_common_dir" == ".git" ]]; then
        repo_name=$(basename "$git_root")
    else
        repo_name=$(basename "$git_root")
    fi
    # Always create worktrees from the main repo at ~/git/<repo>
    local main_repo="$HOME/git/$repo_name"
    if [[ ! -d "$main_repo/.git" ]]; then
        main_repo="$git_root"
    fi

    # Prompt user for worktree context
    echo "What will this worktree be about?"
    echo -n "> "
    local user_context
    read -r user_context
    if [[ -z "$user_context" ]]; then
        echo "Error: context cannot be empty"
        return 1
    fi

    # Generate a kebab-case name using an isolated Claude
    # request with all tools disabled (text-only output)
    echo "Generating worktree name..."
    local raw_name
    raw_name=$(claude -p "Output a git branch name for: $user_context. Use the format prefix/lowercase-kebab-case-name where prefix is one of: feature, bugfix, hotfix, chore, docs, refactor, test. The name part should be 2-4 words. Output only the branch name, nothing else." --tools "" --model haiku 2>/dev/null)

    # Sanitize: lowercase, alphanumeric, dashes, and slashes
    # only, no leading/trailing dashes or slashes, no
    # consecutive dashes
    raw_name=$(echo "$raw_name" | tr '[:upper:]' '[:lower:]')
    raw_name=$(echo "$raw_name" | tr -cd 'a-z0-9/-')
    raw_name=$(echo "$raw_name" | sed 's/^[-/]*//;s/[-/]*$//')
    raw_name=$(echo "$raw_name" | sed 's/-\{2,\}/-/g')

    if [[ ${#raw_name} -lt 1 ]]; then
        echo "Error: could not generate a valid worktree name"
        return 1
    fi

    # Use the full name (with prefix) for both branch and
    # directory, allowing nested directories like
    # bugfix/fix-login under the repo worktree root
    local branch_name="$raw_name"
    local repo_worktree_dir="$HOME/.claude/worktrees/$repo_name"
    local worktree_name="$raw_name"
    if [[ -d "$repo_worktree_dir/$worktree_name" ]]; then
        local n=2
        while [[ -d "$repo_worktree_dir/${worktree_name}-${n}" ]]; do
            ((n++))
        done
        worktree_name="${raw_name}-${n}"
        branch_name="${raw_name}-${n}"
    fi

    local worktree_path="$repo_worktree_dir/$worktree_name"

    # Create parent directories (handles nested prefixes
    # like bugfix/fix-login)
    mkdir -p "$(dirname "$worktree_path")"

    # Create the worktree with a new branch from main repo's HEAD
    echo "Creating worktree \"$worktree_name\" for $repo_name..."
    git -C "$main_repo" worktree add "$worktree_path" -b "$branch_name" 2>/dev/null
    if [[ $? -ne 0 ]]; then
        echo "Error: failed to create worktree"
        return 1
    fi

    # Seed CONTEXT.md with the user's task description
    {
        echo "# Context"
        echo ""
        echo "## Current Task"
        printf "%s\n" "$user_context"
        echo ""
        echo "## Status"
        echo "New worktree, no work done yet."
        echo ""
        echo "## Next Steps"
        echo "- Begin working on the task"
    } > "$worktree_path/CONTEXT.md"

    # Reap stale Claude processes before starting a new one
    _claude_reap_silent 2

    echo "Worktree created at $worktree_path"
    echo "Branch: $branch_name"
    echo "Starting Claude Code..."

    # Set terminal tab title to the full worktree name
    # including prefix (e.g., "bugfix/fix-login")
    printf '\033]1;%s\007' "$worktree_name"
    if [[ -n "$TMUX" ]]; then
        tmux rename-window "$worktree_name"
    fi

    # Launch Claude Code interactively with the initial
    # prompt visible (no hidden -p phase)
    (cd "$worktree_path" && CLAUDE_CODE_DISABLE_TERMINAL_TITLE=1 claude --dangerously-skip-permissions "$user_context")
}

# List all active worktrees across all repos
worktrees() {
    local worktree_root="$HOME/.claude/worktrees"
    if [[ ! -d "$worktree_root" ]]; then
        echo "No worktrees found"
        return 0
    fi

    local found=0
    for repo_dir in "$worktree_root"/*/; do
        [[ -d "$repo_dir" ]] || continue
        local repo_name=$(basename "$repo_dir")

        # Find worktree directories at any depth (they
        # contain a .git file, not a directory)
        while IFS= read -r git_file; do
            local wt_dir="${git_file%/.git}"
            local wt_name="${wt_dir#$repo_dir}"
            local branch=$(git -C "$wt_dir" branch --show-current 2>/dev/null)
            local last_commit=$(git -C "$wt_dir" log -1 --format='%cr' 2>/dev/null)

            if [[ $found -eq 0 ]]; then
                printf "%-20s %-30s %-30s %s\n" "REPO" "WORKTREE" "BRANCH" "LAST ACTIVITY"
                printf "%-20s %-30s %-30s %s\n" "----" "--------" "------" "-------------"
                found=1
            fi
            printf "%-20s %-30s %-30s %s\n" "$repo_name" "$wt_name" "$branch" "$last_commit"
        done < <(fd -t f -H --max-depth 4 '^\.git$' "$repo_dir" 2>/dev/null)
    done

    if [[ $found -eq 0 ]]; then
        echo "No worktrees found"
    fi
}

# Rename a worktree's branch (directory stays the same)
# Usage: wt-rename <new-name>
# Must be run from inside a worktree
wt-rename() {
    local new_name="$1"
    if [[ -z "$new_name" ]]; then
        echo "[Usage] wt-rename <new-name>"
        echo "Renames the current worktree branch."
        return 1
    fi

    # Must be in a worktree (not the main working tree)
    local git_common_dir
    git_common_dir=$(git rev-parse --git-common-dir 2>/dev/null)
    local git_dir
    git_dir=$(git rev-parse --git-dir 2>/dev/null)
    if [[ "$git_common_dir" == "$git_dir" ]]; then
        echo "Error: not inside a worktree (this is the main working tree)"
        return 1
    fi

    # Rename branch only (directory stays put to avoid
    # invalidating Claude Code's tracked CWD)
    git branch -m "$new_name" || return 1
    echo "Renamed branch to \"$new_name\""
}

# Clean up stale worktrees (older than N days, default 7)
# Usage: worktree-cleanup [days]
worktree-cleanup() {
    local max_age_days=${1:-7}
    local worktree_root="$HOME/.claude/worktrees"
    local now=$(date +%s)
    local max_age_seconds=$((max_age_days * 86400))
    local stale=()

    if [[ ! -d "$worktree_root" ]]; then
        echo "No worktrees found"
        return 0
    fi

    for repo_dir in "$worktree_root"/*/; do
        [[ -d "$repo_dir" ]] || continue
        local repo_name=$(basename "$repo_dir")

        # Find worktree directories at any depth (they
        # contain a .git file, not a directory)
        while IFS= read -r git_file; do
            local wt_dir="${git_file%/.git}"
            local wt_name="${wt_dir#$repo_dir}"

            # Get last commit timestamp
            local last_ts=$(git -C "$wt_dir" log -1 --format=%ct 2>/dev/null)
            if [[ -z "$last_ts" ]]; then
                last_ts=0
            fi

            local age=$((now - last_ts))
            if [[ $age -gt $max_age_seconds ]]; then
                local last_commit=$(git -C "$wt_dir" log -1 --format='%cr' 2>/dev/null || echo "unknown")
                local branch=$(git -C "$wt_dir" branch --show-current 2>/dev/null || echo "unknown")
                stale+=("$repo_name|$wt_name|$branch|$last_commit|$wt_dir")
            fi
        done < <(fd -t f -H --max-depth 4 '^\.git$' "$repo_dir" 2>/dev/null)
    done

    if [[ ${#stale[@]} -eq 0 ]]; then
        echo "No stale worktrees found (threshold: $max_age_days days)"
        return 0
    fi

    echo "Stale worktrees (no commits in $max_age_days+ days):"
    echo ""
    printf "%-20s %-30s %-30s %s\n" "REPO" "WORKTREE" "BRANCH" "LAST ACTIVITY"
    printf "%-20s %-30s %-30s %s\n" "----" "--------" "------" "-------------"

    for entry in "${stale[@]}"; do
        IFS='|' read -r repo wt branch last_commit wt_path <<< "$entry"
        printf "%-20s %-30s %-30s %s\n" "$repo" "$wt" "$branch" "$last_commit"
    done

    echo ""
    echo -n "Delete all ${#stale[@]} stale worktrees? [y/N] "
    read -r confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        # Also reap stale Claude processes
        _claude_reap_silent "$max_age_days"

        for entry in "${stale[@]}"; do
            IFS='|' read -r repo wt branch last_commit wt_path <<< "$entry"
            local git_root="$HOME/git/$repo"

            # Kill any Claude process still running in this worktree
            ps -eo pid,command | grep "claude.*--dangerously" | grep -v grep | while read -r pid cmd; do
                local proc_cwd=$(lsof -p "$pid" -Fn 2>/dev/null | grep '^n.*'"$wt_path" | head -1)
                if [[ -n "$proc_cwd" ]]; then
                    kill "$pid" 2>/dev/null
                fi
            done

            # Remove the worktree via git
            if [[ -d "$git_root/.git" ]]; then
                git -C "$git_root" worktree remove "$wt_path" --force 2>/dev/null
            fi

            # Clean up if directory still exists
            if [[ -d "$wt_path" ]]; then
                rm -rf "$wt_path"
            fi

            # Delete the branch if it exists
            if [[ -n "$branch" && "$branch" != "main" && "$branch" != "unknown" ]]; then
                git -C "$git_root" branch -D "$branch" 2>/dev/null
            fi

            echo "Removed $repo/$wt ($branch)"
        done

        # Clean up empty prefix and repo directories
        for repo_dir in "$worktree_root"/*/; do
            [[ -d "$repo_dir" ]] || continue
            # Remove empty prefix directories first
            # (e.g., bugfix/ after all bugfix worktrees
            # are removed)
            fd -t d --max-depth 2 . "$repo_dir" 2>/dev/null | sort -r | while read -r d; do
                rmdir "$d" 2>/dev/null
            done
            # Remove the repo directory if now empty
            rmdir "$repo_dir" 2>/dev/null
        done

        echo "Done"
    else
        echo "Cancelled"
    fi
}

