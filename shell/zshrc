# Claude Process Reaper
# ============================================================================
# Kill orphaned Claude processes older than a threshold
# Processes often become orphans when terminal tabs are closed
# without properly terminating the Claude session

# Kill stale Claude processes older than N days (default 2)
# Usage: claude-reap [days]
claude-reap() {
    local max_age_days=${1:-2}
    local max_age_seconds=$((max_age_days * 86400))
    local current_pid=$$
    local stale_pids=()
    local stale_info=()

    while IFS= read -r line; do
        local pid=$(echo "$line" | awk '{print $1}')
        local elapsed=$(echo "$line" | awk '{print $2}')
        local rss=$(echo "$line" | awk '{print $3}')

        # Skip our own process tree
        if [[ "$pid" == "$current_pid" ]]; then
            continue
        fi

        # Parse elapsed time (format: dd-HH:MM:SS or HH:MM:SS
        # or MM:SS)
        local seconds=0
        if [[ "$elapsed" == *-* ]]; then
            local days=${elapsed%%-*}
            local rest=${elapsed#*-}
            local h=$(echo "$rest" | cut -d: -f1)
            local m=$(echo "$rest" | cut -d: -f2)
            local s=$(echo "$rest" | cut -d: -f3)
            seconds=$(( days * 86400 + h * 3600 + m * 60 + s ))
        elif [[ $(echo "$elapsed" | tr -cd ':' | wc -c) -eq 2 ]]; then
            local h=$(echo "$elapsed" | cut -d: -f1)
            local m=$(echo "$elapsed" | cut -d: -f2)
            local s=$(echo "$elapsed" | cut -d: -f3)
            seconds=$(( h * 3600 + m * 60 + s ))
        else
            local m=$(echo "$elapsed" | cut -d: -f1)
            local s=$(echo "$elapsed" | cut -d: -f2)
            seconds=$(( m * 60 + s ))
        fi

        if [[ $seconds -ge $max_age_seconds ]]; then
            stale_pids+=("$pid")
            local age_days=$((seconds / 86400))
            local rss_mb=$((rss / 1024))
            stale_info+=("PID $pid: ${age_days} days old, ${rss_mb} MB")
        fi
    done < <(ps -eo pid,etime,rss,command | grep "claude.*--dangerously-skip-permissions" | grep -v grep | awk '{print $1, $2, $3}')

    if [[ ${#stale_pids[@]} -eq 0 ]]; then
        echo "No stale Claude processes found (threshold: $max_age_days days)"
        return 0
    fi

    local total=${#stale_pids[@]}
    local suffix="es"
    [[ $total -eq 1 ]] && suffix=""
    echo "Found $total stale Claude process${suffix}:"
    for info in "${stale_info[@]}"; do
        echo "  $info"
    done

    echo ""
    echo -n "Kill all? [y/N] "
    read -r confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        for pid in "${stale_pids[@]}"; do
            kill "$pid" 2>/dev/null && echo "Killed PID $pid"
        done
        echo "Done"
    else
        echo "Cancelled"
    fi
}

# Silently kill Claude processes older than N days (no prompt)
# Used internally by other functions
_claude_reap_silent() {
    local max_age_days=${1:-2}
    local max_age_seconds=$((max_age_days * 86400))
    local current_pid=$$
    local count=0

    while IFS= read -r line; do
        local pid=$(echo "$line" | awk '{print $1}')
        local elapsed=$(echo "$line" | awk '{print $2}')

        [[ "$pid" == "$current_pid" ]] && continue

        local seconds=0
        if [[ "$elapsed" == *-* ]]; then
            local days=${elapsed%%-*}
            local rest=${elapsed#*-}
            local h=$(echo "$rest" | cut -d: -f1)
            local m=$(echo "$rest" | cut -d: -f2)
            local s=$(echo "$rest" | cut -d: -f3)
            seconds=$(( days * 86400 + h * 3600 + m * 60 + s ))
        elif [[ $(echo "$elapsed" | tr -cd ':' | wc -c) -eq 2 ]]; then
            local h=$(echo "$elapsed" | cut -d: -f1)
            local m=$(echo "$elapsed" | cut -d: -f2)
            local s=$(echo "$elapsed" | cut -d: -f3)
            seconds=$(( h * 3600 + m * 60 + s ))
        else
            local m=$(echo "$elapsed" | cut -d: -f1)
            local s=$(echo "$elapsed" | cut -d: -f2)
            seconds=$(( m * 60 + s ))
        fi

        if [[ $seconds -ge $max_age_seconds ]]; then
            kill "$pid" 2>/dev/null && ((count++))
        fi
    done < <(ps -eo pid,etime,command | grep "claude.*--dangerously-skip-permissions" | grep -v grep | awk '{print $1, $2}')

    if [[ $count -gt 0 ]]; then
        local suffix="es"
        [[ $count -eq 1 ]] && suffix=""
        echo "Reaped $count stale Claude process${suffix}"
    fi
}

