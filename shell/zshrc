# Quick summary of Claude process memory usage
claude-mem() {
    local count=0
    local total_mb=0
    while IFS= read -r line; do
        local pid=$(echo "$line" | awk '{print $1}')
        local rss=$(echo "$line" | awk '{print $2}')
        local elapsed=$(echo "$line" | awk '{print $3}')
        local mb=$((rss / 1024))
        total_mb=$((total_mb + mb))
        ((count++))
        printf "  PID %-6s  %4d MB  uptime %s\n" "$pid" "$mb" "$elapsed"
    done < <(ps -eo pid,rss,etime,command | grep "claude.*--dangerously-skip-permissions" | grep -v grep | awk '{print $1, $2, $3}' | sort -t' ' -k2 -rn)

    if [[ $count -eq 0 ]]; then
        echo "No Claude processes running"
    else
        local suffix="es"
        [[ $count -eq 1 ]] && suffix=""
        echo ""
        echo "$count process${suffix}, $total_mb MB total"
    fi
}
