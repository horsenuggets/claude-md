# ============================================================================
# Claude Session Recovery
# ============================================================================
# Find and resume crashed or lost Claude sessions

# List recent Claude sessions for the current directory (or a
# given path), sorted by most recent. Shows session ID, date,
# message count, and summary for easy identification.
# Usage: claude-recover [path] [count]
claude-recover() {
    local search_path="${1:-$PWD}"
    local max_results="${2:-10}"

    # Resolve to absolute path
    search_path=$(cd "$search_path" 2>/dev/null && pwd)
    if [[ -z "$search_path" ]]; then
        echo "Error: invalid path \"$1\""
        return 1
    fi

    # Convert path to Claude's project directory format
    # (slashes become dashes, leading slash becomes dash)
    local project_dir_name=$(echo "$search_path" | sed 's|/|-|g')

    # Find all matching session index files
    local found=0
    local sessions=()

    for index_file in "$HOME/.claude/projects"/*/sessions-index.json; do
        [[ -f "$index_file" ]] || continue

        # Read sessions that match the search path
        while IFS=$'\t' read -r sid modified msgs summary project branch; do
            sessions+=("$modified|$sid|$msgs|$summary|$project|$branch")
        done < <(python3 -c "
import json, sys
with open('$index_file') as f:
    data = json.load(f)
for e in data.get('entries', []):
    pp = e.get('projectPath', '')
    if pp.startswith('$search_path'):
        sid = e['sessionId']
        mod = e.get('modified', '')[:19]
        msgs = e.get('messageCount', 0)
        summary = e.get('summary', '(no summary)')
        branch = e.get('gitBranch', '')
        print(f'{sid}\t{mod}\t{msgs}\t{summary}\t{pp}\t{branch}')
" 2>/dev/null)
    done

    if [[ ${#sessions[@]} -eq 0 ]]; then
        echo "No sessions found for \"$search_path\""
        echo ""
        echo "Try a parent directory or check"
        echo "~/.claude/projects/ for available paths."
        return 1
    fi

    # Sort by date (descending) and limit
    local sorted=()
    while IFS= read -r line; do
        sorted+=("$line")
    done < <(printf "%s\n" "${sessions[@]}" | sort -t'|' -k1 -r | head -"$max_results")

    echo "Recent sessions for $search_path"
    echo ""
    printf "  %-3s %-19s %4s  %s\n" "#" "DATE" "MSGS" "SUMMARY"
    printf "  %-3s %-19s %4s  %s\n" "---" "-------------------" "----" "-------"

    local i=1
    local session_ids=()
    for entry in "${sorted[@]}"; do
        IFS='|' read -r modified sid msgs summary project branch <<< "$entry"
        session_ids+=("$sid")
        local branch_info=""
        if [[ -n "$branch" ]]; then
            branch_info=" [$branch]"
        fi
        printf "  %-3s %-19s %4s  %s%s\n" "$i" "$modified" "$msgs" "$summary" "$branch_info"
        ((i++))
    done

    echo ""
    echo "Resume a session with:"
    echo "  claude --resume <session-id>"
    echo ""
    echo "Or continue the most recent session in this directory:"
    echo "  claude --continue"
    echo ""

    # Offer quick resume
    echo -n "Resume session # (or press Enter to skip): "
    read -r choice
    if [[ -n "$choice" && "$choice" =~ ^[0-9]+$ ]]; then
        local idx=$((choice - 1))
        if [[ $idx -ge 0 && $idx -lt ${#session_ids[@]} ]]; then
            local resume_id="${session_ids[$idx]}"
            echo ""
            echo "Resuming session $resume_id..."
            (cd "$search_path" && claude --resume "$resume_id" --dangerously-skip-permissions)
        else
            echo "Invalid selection"
        fi
    fi
}

# Quick session search across all projects by keyword
# Usage: claude-find <keyword>
claude-find() {
    local keyword="$1"
    if [[ -z "$keyword" ]]; then
        echo "[Usage] claude-find <keyword>"
        echo "Search session summaries and first prompts."
        return 1
    fi

    local results=()
    for index_file in "$HOME/.claude/projects"/*/sessions-index.json; do
        [[ -f "$index_file" ]] || continue
        while IFS=$'\t' read -r sid modified msgs summary project; do
            results+=("$modified|$sid|$msgs|$summary|$project")
        done < <(python3 -c "
import json
with open('$index_file') as f:
    data = json.load(f)
kw = '$keyword'.lower()
for e in data.get('entries', []):
    summary = e.get('summary', '')
    prompt = e.get('firstPrompt', '')
    if kw in summary.lower() or kw in prompt.lower():
        sid = e['sessionId']
        mod = e.get('modified', '')[:19]
        msgs = e.get('messageCount', 0)
        pp = e.get('projectPath', '')
        print(f'{sid}\t{mod}\t{msgs}\t{summary}\t{pp}')
" 2>/dev/null)
    done

    if [[ ${#results[@]} -eq 0 ]]; then
        echo "No sessions matching \"$keyword\""
        return 1
    fi

    local sorted=()
    while IFS= read -r line; do
        sorted+=("$line")
    done < <(printf "%s\n" "${results[@]}" | sort -t'|' -k1 -r | head -15)

    echo "Sessions matching \"$keyword\""
    echo ""
    printf "  %-19s %4s  %-40s %s\n" "DATE" "MSGS" "SUMMARY" "PROJECT"
    printf "  %-19s %4s  %-40s %s\n" "-------------------" "----" "----------------------------------------" "-------"

    for entry in "${sorted[@]}"; do
        IFS='|' read -r modified sid msgs summary project <<< "$entry"
        # Shorten project path
        local short_project="${project/#$HOME/~}"
        # Truncate summary
        if [[ ${#summary} -gt 40 ]]; then
            summary="${summary:0:37}..."
        fi
        printf "  %-19s %4s  %-40s %s\n" "$modified" "$msgs" "$summary" "$short_project"
        echo "    claude --resume $sid"
    done
}

