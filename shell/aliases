# Common aliases for Claude workflow
# Source this file from your shell rc file or copy to ~/.aliases

# Claude shortcuts
alias cld="claude --dangerously-skip-permissions"
alias gst="git status"
alias wt='worktrees'
alias wtc='worktree-cleanup'
alias wtr='wt-rename'

# Additional useful aliases
alias cfind='claude-find'
alias cls='claude-ls'
alias cmem='claude-mem'
alias crepo='claude-repo'
alias crp='claude-reap'
alias csp='claude-spawn'
alias crc='claude-recover'
